OPENAI_API_KEY=your_openai_compatible_api_key
OPENAI_BASE_URL=https://api.example.com/v1
OPENAI_MODEL=openai/gpt-4o-mini
ENABLE_FETCH_MCP=0
UVX_COMMAND=uvx
ENABLE_AUTO_CAREER_FETCH=1
CAREER_FETCH_MAX_SOURCES=10
ENABLE_PLAYWRIGHT_FETCH=1
CAREER_JOB_MAX_RESULTS=5
CAREER_JOB_MAX_DETAIL_PAGES=5
CAREER_JOB_MAX_TOTAL_RESULTS=20
RAG_TOP_K=8
CONTEXT_MAX_CHARS=15000
EMBEDDING_KEY=your_embedding_api_key
EMBEDDING_BASE_URL=https://api.example.com/v1
EMBEDDING_MODEL=BAAI/bge-m3
OUTPUT_DIR=./output
KNOWLEDGE_DIR=./knowledge
